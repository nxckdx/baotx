#!/usr/bin/env bash
set -eo pipefail

# BaoTx - Context & Login Manager for OpenBao / Vault
# Refactored for dynamic subcommands

# Handle multiple config files (like KUBECONFIG)
VERSION="baotx-v1.1.3"
readonly VERSION
IFS=':' read -ra CONFIG_FILES <<< "${BAOTX_CONFIG:-$HOME/.baoconfig.yaml}"
readonly PRIMARY_CONFIG="${CONFIG_FILES[0]}"
readonly SCRIPT_PATH="$(readlink -f "$0")"
readonly DATA_DIR="$HOME/.local/share/baotx"
readonly REPO_OWNER="nxckdx"
readonly REPO_NAME="baotx"

# --- Helper Functions ---

_log() { echo -e "$*" >&2; }
_error() { _log "Error: $*"; exit 1; }

_get_config() {
    local query="$1"
    local files=()
    # Check which files actually exist
    for f in "${CONFIG_FILES[@]}"; do
        [[ -f "$f" ]] && files+=("$f")
    done

    if [[ ${#files[@]} -eq 0 ]]; then
        return
    elif [[ ${#files[@]} -eq 1 ]]; then
        yq "$query" "${files[0]}" 2>/dev/null
    else
        # Merge files: the first one in the list has the highest precedence.
        # yq merges from left to right, where right overwrites left.
        # So we reverse the list for the 'ireduce' operation.
        local rev_files=()
        for (( i=${#files[@]}-1; i>=0; i-- )); do
            rev_files+=("${files[i]}")
        done
        yq eval-all ". as \$item ireduce ({}; . * \$item) | $query" "${rev_files[@]}" 2>/dev/null
    fi
}

_set_config() {
    # Write operations always target the primary (first) config file
    if [[ ! -f "$PRIMARY_CONFIG" ]]; then
        # Create it if it doesn't exist yet
        touch "$PRIMARY_CONFIG"
        chmod 600 "$PRIMARY_CONFIG"
    fi
    yq -i "$1" "$PRIMARY_CONFIG"
}

_check_deps() {
    for cmd in fzf jq yq curl; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            _error "Required tool \"$cmd\" is not installed."
        fi
    done
    
    mkdir -p "$DATA_DIR"
}

_get_storage_backend() {
    local backend
    backend=$(_get_config '.token_storage // "keyring"')
    echo "$backend"
}

_store_token() {
    local cluster="$1" token="$2"
    local backend
    backend=$(_get_storage_backend)

    case "$backend" in
        keyring)
            if command -v secret-tool >/dev/null 2>&1; then
                secret-tool store --label="BaoTx: $cluster" service baotx cluster "$cluster" <<< "$token"
            elif command -v security >/dev/null 2>&1; then
                security add-generic-password -a "$USER" -s "baotx-$cluster" -w "$token" -U
            else
                _log "Warning: No keyring tool found. Falling back to plain text."
                _set_config ".clusters.\"$cluster\".token = \"$token\""
            fi
            ;;
        gpg)
            local key_id
            key_id=$(_get_config '.storage_key')
            [[ -z "$key_id" || "$key_id" == "null" ]] && _error "token_storage is 'gpg' but storage_key (GPG Key ID) is not set."
            echo "$token" | gpg --encrypt --recipient "$key_id" --armor > "$DATA_DIR/$cluster.gpg"
            ;;
        age)
            local key_id
            key_id=$(_get_config '.storage_key')
            [[ -z "$key_id" || "$key_id" == "null" ]] && _error "token_storage is 'age' but storage_key (Public Key) is not set."
            echo "$token" | age -r "$key_id" -a > "$DATA_DIR/$cluster.age"
            ;;
        plain)
            _set_config ".clusters.\"$cluster\".token = \"$token\""
            ;;
        *) _error "Unknown token_storage backend: $backend" ;;
    esac
}

_retrieve_token() {
    local cluster="$1"
    local backend token
    backend=$(_get_storage_backend)

    case "$backend" in
        keyring)
            if command -v secret-tool >/dev/null 2>&1; then
                token=$(secret-tool lookup service baotx cluster "$cluster")
            elif command -v security >/dev/null 2>&1; then
                token=$(security find-generic-password -a "$USER" -s "baotx-$cluster" -w 2>/dev/null)
            fi
            ;;
        gpg)
            if [[ -f "$DATA_DIR/$cluster.gpg" ]]; then
                token=$(gpg --decrypt "$DATA_DIR/$cluster.gpg" 2>/dev/null)
            fi
            ;;
        age)
            local identity
            identity=$(_get_config '.storage_identity') # age needs a private key/identity file for decryption
            if [[ -f "$DATA_DIR/$cluster.age" ]]; then
                if [[ -n "$identity" && "$identity" != "null" ]]; then
                    token=$(age --decrypt -i "$identity" "$DATA_DIR/$cluster.age" 2>/dev/null)
                else
                    token=$(age --decrypt "$DATA_DIR/$cluster.age" 2>/dev/null)
                fi
            fi
            ;;
        plain)
            token=$(_get_config ".clusters.\"$cluster\".token // \"\"")
            ;;
    esac

    # Fallback to config file if not found in backend (for transition)
    if [[ -z "$token" || "$token" == "null" ]]; then
        token=$(_get_config ".clusters.\"$cluster\".token // \"\"")
    fi
    echo "$token"
}

_delete_token() {
    local cluster="$1"
    local backend
    backend=$(_get_storage_backend)

    case "$backend" in
        keyring)
            if command -v secret-tool >/dev/null 2>&1; then
                secret-tool clear service baotx cluster "$cluster"
            elif command -v security >/dev/null 2>&1; then
                security delete-generic-password -a "$USER" -s "baotx-$cluster" 2>/dev/null || true
            fi
            ;;
        gpg) rm -f "$DATA_DIR/$cluster.gpg" ;;
        age) rm -f "$DATA_DIR/$cluster.age" ;;
    esac
    _set_config "del(.clusters.\"$cluster\".token)"
}

_get_cli_tool() {
    local tool
    tool=$(_get_config '.cli_tool // ""')
    if [[ -z "$tool" || "$tool" == "null" ]]; then
        if command -v bao >/dev/null 2>&1; then tool="bao"
        elif command -v vault >/dev/null 2>&1; then tool="vault"
        else tool="curl"; fi
    fi
    echo "$tool"
}

_resolve_alias() {
    local target="$1"
    # 1. Check if it's a direct cluster name
    if [[ $(_get_config ".clusters.\"$target\"") != "null" ]]; then
        echo "$target"
        return
    fi
    # 2. Check if it's an alias
    # This query finds the key of a cluster that has the target in its aliases list
    local resolved
    resolved=$(_get_config ".clusters | to_entries | .[] | select(.value.aliases[] == \"$target\") | .key")
    if [[ -n "$resolved" && "$resolved" != "null" ]]; then
        echo "$resolved"
    else
        echo "$target"
    fi
}

_check_health() {
    local addr="$1"
    # Use a short timeout for health checks
    if curl -s -f -m 2 "$addr/v1/sys/health" >/dev/null 2>&1; then
        echo "online"
    else
        echo "offline"
    fi
}

_export_context() {
    local cluster="$1" addr="$2" token="$3" ns="${4:-}"
    echo "export VAULT_ADDR=\"$addr\""
    echo "export VAULT_TOKEN=\"$token\""
    echo "export BAO_ADDR=\"$addr\""
    echo "export BAO_TOKEN=\"$token\""
    echo "export BAOTX_CLUSTER=\"$cluster\""
    if [[ -n "$ns" && "$ns" != "null" ]]; then
        echo "export VAULT_NAMESPACE=\"$ns\""
        echo "export BAO_NAMESPACE=\"$ns\""
    else
        echo "unset VAULT_NAMESPACE BAO_NAMESPACE"
    fi
}

_baotx_logo(){
    _log "  ____              _______      "
    _log " |  _ \            |__   __|     "
    _log " | |_) | __ _  ___   | |_  __  "
    _log " |  _ < / _\` |/ _ \  | \ \/ /  "
    _log " | |_) | (_| | (_) | | |>  <   "
    _log " |____/ \__,_|\___/  |_/_/\_\  "
}

# --- Subcommand Functions ---

# DESC: Checks for updates and installs the latest version
cmd_update() {
    local latest_version
    _log "Checking for updates..."
    latest_version=$(curl -s "https://api.github.com/repos/$REPO_OWNER/$REPO_NAME/releases/latest" | jq -r .tag_name)
    
    if [[ "$latest_version" == "null" ]]; then
        _error "Could not find any releases for $REPO_OWNER/$REPO_NAME."
    fi

    if [[ "$latest_version" == "v$VERSION" || "$latest_version" == "$VERSION" ]]; then
        _log "BaoTx is already up to date ($VERSION)."
    else
        _log "Updating BaoTx from $VERSION to $latest_version..."
        # Download to a temp file first
        local tmp_bin
        tmp_bin=$(mktemp)
        if curl -sSLf "https://github.com/$REPO_OWNER/$REPO_NAME/releases/latest/download/baotx" -o "$tmp_bin"; then
            chmod +x "$tmp_bin"
            mv "$tmp_bin" "$SCRIPT_PATH"
            _log "Update successful! Please restart your shell."
        else
            _error "Download failed. The release asset might not be available yet."
        fi
    fi
}

# DESC: Shows this help message
cmd_help() {
    _baotx_logo
    _log ""
    _log "BaoTx - Context & Login Manager for OpenBao / Vault"
    _log "--------------------------------"
    _log "\nUsage: baotx <command> [arguments]\n"
    _log "Commands:"
    
    # Dynamically extract commands and their DESC comments
    grep -E "^# DESC:|^cmd_" "$SCRIPT_PATH" | while read -r line; do
        if [[ "$line" =~ ^#\ DESC:\ (.*) ]]; then
            desc="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^cmd_([a-zA-Z0-9_-]+)\(\) ]]; then
            name="${BASH_REMATCH[1]}"
            printf "  %-15s %s\n" "$name" "$desc" >&2
        fi
    done
    _log ""
    _log "Environment Variables:"
    _log "  BAOTX_CONFIG    Path to the config file (default: \$HOME/.baoconfig.yaml)"
    _log ""
}

# DESC: Creates a configuration template
cmd_init() {
    if [[ -f "$PRIMARY_CONFIG" ]]; then
        _error "Configuration file $PRIMARY_CONFIG already exists!"
    fi
    cat <<EOF > "$PRIMARY_CONFIG"
cli_tool: ""
clusters:
  dev-cluster:
    address: "https://bao-dev.example.com"
    login: "userpass"
    aliases: ["dev", "d"]
    last_authentication: ""
    token: ""
    expire_token: ""
current-cluster: ""
EOF
    chmod 600 "$PRIMARY_CONFIG"
    _log "Template successfully created at $PRIMARY_CONFIG."
}

# DESC: Shows current context and token TTL (use --format=env for .env output)
cmd_status() {
    local format=""
    for arg in "$@"; do
        case "$arg" in
            --format=env) format="env" ;;
        esac
    done

    local cur
    cur=$(_get_config '.current-cluster')

    if [[ "$format" == "env" ]]; then
        if [[ -n "$cur" && "$cur" != "null" ]]; then
            local addr token ns
            addr=$(_get_config ".clusters.\"$cur\".address")
            token=$(_retrieve_token "$cur")
            ns=$(_get_config ".clusters.\"$cur\".namespace")
            
            echo "export VAULT_ADDR=\"$addr\""
            echo "export VAULT_TOKEN=\"$token\""
            echo "export BAO_ADDR=\"$addr\""
            echo "export BAO_TOKEN=\"$token\""
            echo "export BAOTX_CLUSTER=\"$cur\""
            if [[ -n "$ns" && "$ns" != "null" ]]; then
                echo "export VAULT_NAMESPACE=\"$ns\""
                echo "export BAO_NAMESPACE=\"$ns\""
            fi
        fi
        return
    fi

    _baotx_logo
    _log ""
    if [[ -z "$cur" || "$cur" == "null" ]]; then
        _log "No cluster selected."
    else
        local addr exp ns diff hours mins token
        addr=$(_get_config ".clusters.\"$cur\".address")
        exp=$(_get_config ".clusters.\"$cur\".expire_token")
        ns=$(_get_config ".clusters.\"$cur\".namespace")
        token=$(_retrieve_token "$cur")
        _log "--- BaoTx Status ---"
        _log "Version:   ${VERSION}"
        _log "Cluster:   $cur"
        _log "Address:   $addr"
        [[ -n "$ns" && "$ns" != "null" ]] && _log "Namespace: $ns"
        if [[ -n "$token" ]]; then
            if [[ -n "$exp" && "$exp" != "null" ]]; then
                diff=$(($(date -d "$exp" +%s) - $(date +%s)))
                if (( diff <= 0 )); then
                    _log "Token:     EXPIRED"
                else
                    hours=$((diff / 3600))
                    mins=$(( (diff % 3600) / 60 ))
                    _log "Token:     Valid for ${hours}h ${mins}m"
                fi
            else
                _log "Token:     Valid (no expiry set)"
            fi
        else
            _log "Token:     NOT LOGGED IN"
        fi
    fi
}

# DESC: Silently loads the current context (used for .zshrc)
cmd_load() {
    local cur addr token ns
    cur=$(_get_config '.current-cluster')
    if [[ -n "$cur" && "$cur" != "null" ]]; then
        addr=$(_get_config ".clusters.\"$cur\".address")
        token=$(_retrieve_token "$cur")
        ns=$(_get_config ".clusters.\"$cur\".namespace")
        _export_context "$cur" "$addr" "$token" "$ns"
    fi
}

# DESC: Clears current context and environment variables
cmd_clear() {
    local cur
    cur=$(_get_config '.current-cluster')
    if [[ -n "$cur" && "$cur" != "null" ]]; then
        _delete_token "$cur"
    fi
    _set_config '.current-cluster = ""'
    _log "Context cleared."
    echo "unset VAULT_ADDR VAULT_TOKEN BAO_ADDR BAO_TOKEN BAOTX_CLUSTER VAULT_NAMESPACE BAO_NAMESPACE"
}

# DESC: Alias for clear
cmd_unset() { cmd_clear; }

# DESC: Sets the path to the bao/vault binary
cmd_set-cli() {
    if [[ -z "${1:-}" ]]; then _error "Usage: baotx set-cli <path>"; fi
    _set_config ".cli_tool = \"$1\""
    _log "CLI tool updated to: $1"
}

# DESC: Selects a cluster (interactive via fzf if no name given)
cmd_select() {
    local selected="$1"
    local cli_tool clusters
    cli_tool=$(_get_cli_tool)

    if [[ -z "$selected" ]]; then
        # We use a temporary file to store health results to avoid blocking fzf
        local health_tmp
        health_tmp=$(mktemp)
        
        # Get clusters and their addresses
        local cluster_data
        cluster_data=$(_get_config '.clusters | to_entries | .[] | .key + " " + .value.address')

        # Start health checks in background
        while read -r name addr; do
            (
                local status
                status=$(_check_health "$addr")
                echo "$name $status" >> "$health_tmp"
            ) &
        done <<< "$cluster_data"

        # Prepare the list for fzf with ansi colors
        # This is a bit tricky: we want fzf to show the list immediately,
        # but we also want the colors. Since the background checks might take a second,
        # we'll build a preview/list that includes the status.
        
        # Wait a tiny bit for the first results, but not too long
        sleep 0.2

        local fzf_input
        fzf_input=$(while read -r name addr; do
            local aliases status_color="[..]" status_text=""
            aliases=$(_get_config ".clusters.\"$name\".aliases | join(\", \")" 2>/dev/null || echo "")
            [[ "$aliases" == "null" ]] && aliases=""
            
            # Check if we already have a health result
            local health
            health=$(grep "^$name " "$health_tmp" | cut -d' ' -f2 || true)
            
            if [[ "$health" == "online" ]]; then
                status_color="\e[32m[ok]\e[0m"
            elif [[ "$health" == "offline" ]]; then
                status_color="\e[31m[!!]\e[0m"
            fi

            local display_name="$name"
            [[ -n "$aliases" ]] && display_name="$name [$aliases]"
            
            printf "%-30s %b\n" "$display_name" "$status_color"
        done <<< "$cluster_data")

        selected=$(echo -e "$fzf_input" | fzf --ansi \
            --prompt="${cli_tool^^} Cluster > " \
            --height=40% --layout=reverse \
            --header="[ok]=Online  [!!]=Offline  [..]=Checking...")
        
        rm -f "$health_tmp"
        
        # Strip aliases and status from selection
        selected="${selected%% *}"
    else
        selected=$(_resolve_alias "$selected")
    fi

    [[ -z "$selected" || "$selected" == "null" ]] && return

    _perform_switch "$selected" 0
}

# DESC: Selects a namespace for the current cluster
cmd_namespace() {
    local cur selected cli_tool addr token namespaces
    cur=$(_get_config '.current-cluster')
    if [[ -z "$cur" || "$cur" == "null" ]]; then
        _error "No cluster selected. Run 'baotx select' first."
    fi

    # Check if we need a login, but don't force a switch/export yet
    cli_tool=$(_get_cli_tool)
    addr=$(_get_config ".clusters.\"$cur\".address")
    token=$(_retrieve_token "$cur")
    local exp_token=$(_get_config ".clusters.\"$cur\".expire_token")

    local needs_login=0
    if [[ -z "$token" || "$token" == "null" ]]; then needs_login=1
    elif [[ -n "$exp_token" && "$exp_token" != "null" ]]; then
        [[ $(($(date -d "$exp_token" +%s) - 60)) -lt $(date +%s) ]] && needs_login=1
    fi
    
    # If token is expired or missing, perform a normal switch (which handles login)
    if [[ "$needs_login" -eq 1 ]]; then
        eval "$(_perform_switch "$cur" 0)" >/dev/null
        token=$(_get_config ".clusters.\"$cur\".token")
    fi

    _log "Fetching namespaces from $cur..."
    
    if [[ "$cli_tool" == "curl" ]]; then
        namespaces=$(curl -s -f -H "X-Vault-Token: $token" "$addr/v1/sys/namespaces?list=true" | jq -r '.data.keys[]' 2>/dev/null || true)
    else
        namespaces=$(VAULT_ADDR="$addr" VAULT_TOKEN="$token" VAULT_NAMESPACE="" "$cli_tool" namespace list -format=json 2>/dev/null | jq -r '.[]' 2>/dev/null || true)
    fi

    # Add root option and clean up
    namespaces=$(echo -e "root\n$namespaces" | grep -v "^null$" | sed 's/\/$//' | sort -u || echo "root")

    selected=$(echo "$namespaces" | fzf --prompt="Namespace > " --height=40% --layout=reverse)
    [[ -z "$selected" ]] && return

    if [[ "$selected" == "root" ]]; then
        _set_config "del(.clusters.\"$cur\".namespace)"
        _log "Namespace cleared (root)."
        _export_context "$cur" "$addr" "$token" ""
    else
        _set_config ".clusters.\"$cur\".namespace = \"$selected\""
        _log "Namespace set to: $selected"
        _export_context "$cur" "$addr" "$token" "$selected"
    fi
}

# DESC: Alias for namespace
cmd_ns() { cmd_namespace "$@"; }

# DESC: Forces a login for a cluster (defaults to current)
cmd_login() {
    local selected="${1:-}"
    local method="${2:-}"
    
    # If no argument, try to get the current cluster
    if [[ -z "$selected" ]]; then
        selected=$(_get_config '.current-cluster')
    else
        selected=$(_resolve_alias "$selected")
    fi

    if [[ -z "$selected" || "$selected" == "null" ]]; then
        _error "No cluster specified and no current cluster set. Use 'baotx select' first."
    fi
    
    _perform_switch "$selected" 1 "$method"
}

# Internal function for switching and login logic
_perform_switch() {
    local selected="$1"
    local force_login="$2"
    local override_method="${3:-}"
    local addr login_method token exp_token cli_tool ns
    
    addr=$(_get_config ".clusters.\"$selected\".address")
    if [[ "$addr" == "null" ]]; then _error "Cluster \"$selected\" not found."; fi
    
    # Logic to handle login as a string or a list
    if [[ -n "$override_method" ]]; then
        login_method="$override_method"
    else
        # yq query: if it's a sequence, take the first element, otherwise take the value
        login_method=$(_get_config "(.clusters.\"$selected\".login | (select(tag == \"!!seq\") | .[0]) // .)")
    fi

    token=$(_retrieve_token "$selected")
    exp_token=$(_get_config ".clusters.\"$selected\".expire_token")
    ns=$(_get_config ".clusters.\"$selected\".namespace")
    cli_tool=$(_get_cli_tool)

    local needs_login="$force_login"
    if [[ "$needs_login" -eq 0 ]]; then
        if [[ -z "$token" || "$token" == "null" ]]; then needs_login=1
        elif [[ -n "$exp_token" && "$exp_token" != "null" ]]; then
            [[ $(($(date -d "$exp_token" +%s) - 60)) -lt $(date +%s) ]] && needs_login=1
        fi
        
        if [[ "$needs_login" -eq 0 ]]; then
            if [[ "$cli_tool" == "curl" ]]; then
                ! curl -s -f -H "X-Vault-Token: $token" "$addr/v1/auth/token/lookup-self" >/dev/null 2>&1 && needs_login=1
            else
                ! VAULT_ADDR="$addr" VAULT_TOKEN="$token" "$cli_tool" token lookup >/dev/null 2>&1 && needs_login=1
            fi
        fi
    fi

    if [[ "$needs_login" -eq 1 ]]; then
        if [[ "$cli_tool" == "curl" ]]; then _error "Login not possible via curl. Install bao/vault."; fi
        _log "Logging into $selected..."
        local login_json dur now
        login_json=$("$cli_tool" login -method="$login_method" -address="$addr" -format=json) || _error "Login failed!"
        
        token=$(echo "$login_json" | jq -r '.auth.client_token')
        dur=$(echo "$login_json" | jq -r '.auth.lease_duration')
        exp_token=$(date -d "+$dur seconds" -Iseconds)
        now=$(date -Iseconds)
        
        _store_token "$selected" "$token"
        _set_config ".clusters.\"$selected\".expire_token = \"$exp_token\" | .clusters.\"$selected\".last_authentication = \"$now\" | .current-cluster = \"$selected\""
        _log "Login successful. Valid until: $exp_token"
    else
        _log "Switched to $selected"
        _set_config ".current-cluster = \"$selected\""
    fi

    _export_context "$selected" "$addr" "$token" "$ns"
}

# DESC: Runs a command in a specific cluster context
cmd_exec() {
    local target="$1"
    shift
    if [[ -z "$target" || "$target" == -* || -z "$1" ]]; then
        _log "Usage: baotx exec <cluster|alias> <command> [args...]"
        exit 1
    fi

    local cluster
    cluster=$(_resolve_alias "$target")
    
    local addr token ns
    addr=$(_get_config ".clusters.\"$cluster\".address")
    if [[ "$addr" == "null" ]]; then _error "Cluster \"$cluster\" not found."; fi

    token=$(_retrieve_token "$cluster")
    if [[ -z "$token" || "$token" == "null" ]]; then
        _error "Not logged into $cluster. Run 'baotx login $target' first."
    fi

    ns=$(_get_config ".clusters.\"$cluster\".namespace")

    export VAULT_ADDR="$addr"
    export VAULT_TOKEN="$token"
    export BAO_ADDR="$addr"
    export BAO_TOKEN="$token"
    export BAOTX_CLUSTER="$cluster"
    if [[ -n "$ns" && "$ns" != "null" ]]; then
        export VAULT_NAMESPACE="$ns"
        export BAO_NAMESPACE="$ns"
    fi

    exec "$@"
}

# DESC: Generates auto-completion scripts
cmd_completion() {
    local shell="$1"
    local name desc
    local cmd_list_zsh="" cmd_list_bash=""

    # Dynamically discover commands and descriptions
    while read -r line; do
        if [[ "$line" =~ ^#\ DESC:\ (.*) ]]; then
            desc="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^cmd_([a-zA-Z0-9_-]+)\(\) ]]; then
            name="${BASH_REMATCH[1]}"
            local escaped_desc="${desc//\'/\'\'}"
            cmd_list_zsh+="'$name:$escaped_desc' "
            cmd_list_bash+="$name "
        fi
    done < <(grep -E "^# DESC:|^cmd_" "$SCRIPT_PATH")

    case "$shell" in
        zsh)
            cat << 'EOF' | sed "s|##CMD_LIST_ZSH##|$cmd_list_zsh|g"
_baotx_completion() {
    local -a baotx_clusters
    local config_list="${BAOTX_CONFIG:-$HOME/.baoconfig.yaml}"
    
    # ZSH-idiomatic way to split string into array
    local -a configs
    configs=("${(@s.:.)config_list}")

    local -a existing_configs
    for f in "${configs[@]}"; do [[ -f "$f" ]] && existing_configs+=("$f"); done

    if [[ ${#existing_configs[@]} -gt 0 ]]; then
        # Get both cluster names and their aliases from all files
        baotx_clusters=(${(f)"$(yq eval-all '(.clusters // {}) | to_entries | .[] | (.key, (.value.aliases // [] | .[]))' "${existing_configs[@]}" 2>/dev/null | grep -v "^null$" || true)"})
    fi

    if (( CURRENT == 2 )); then
        local -a cmds
        cmds=( ##CMD_LIST_ZSH## )
        _describe -t commands 'baotx commands' cmds
    elif (( CURRENT == 3 )); then
        case "$words[2]" in
            login|select|namespace|ns|exec)
                _describe -t clusters 'clusters' baotx_clusters
                ;;
            status)
                local -a flags
                flags=('--format=env:Output environment variables')
                _describe -t flags 'flags' flags
                ;;
            set-cli)
                _files
                ;;
        esac
    fi
}
compdef _baotx_completion baotx
EOF
            ;;
        bash)
            cat << 'EOF' | sed "s|##CMD_LIST_BASH##|$cmd_list_bash|g"
_baotx_bash_completion() {
    local cur prev opts clusters config_list
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    config_list="${BAOTX_CONFIG:-$HOME/.baoconfig.yaml}"
    opts="##CMD_LIST_BASH##"

    local -a configs
    IFS=':' read -ra configs <<< "$config_list"
    local existing_configs=()
    for f in "${configs[@]}"; do [[ -f "$f" ]] && existing_configs+=("$f"); done

    if [[ ${#existing_configs[@]} -gt 0 ]]; then
        # Get both cluster names and their aliases from all files
        clusters=$(yq eval-all '(.clusters // {}) | to_entries | .[] | (.key, (.value.aliases // [] | .[]))' "${existing_configs[@]}" 2>/dev/null | grep -v "^null$" || true)
    fi

    if [ $COMP_CWORD -eq 1 ]; then
        COMPREPLY=( $(compgen -W "$opts" -- "$cur") )
        return 0
    fi
    case "$prev" in
        login|select|namespace|ns|exec) COMPREPLY=( $(compgen -W "$clusters" -- "$cur") ); return 0 ;;
        status) COMPREPLY=( $(compgen -W "--format=env" -- "$cur") ); return 0 ;;
        set-cli) COMPREPLY=( $(compgen -f -- "$cur") ); return 0 ;;
    esac
}
complete -F _baotx_bash_completion baotx
EOF
            ;;
        *) _error "Usage: baotx completion [zsh|bash]";;
    esac
}

