{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "node",
      "version-file": "VERSION",
      "extra-files": [
        "package.json",
        {
          "type": "regex",
          "path": "baotx",
          "updater": {
            "search": "VERSION=\"[^\"]*\"",
            "replace": "VERSION=\"{{version}}\""
          }
        }
      ]
    }
  }
}
