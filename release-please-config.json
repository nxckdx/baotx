{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "extra-files": [
        {
          "type": "regex",
          "path": "baotx",
          "updater": {
            "search": "readonly VERSION=\"[^\"]+\"",
            "replace": "readonly VERSION=\"{{version}}\""
          }
        }
      ]
    }
  }
}
